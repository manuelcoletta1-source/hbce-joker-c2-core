{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hbce.example/schemas/evidence_record.json",
  "title": "HBCE JOKER-C2 Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "request_id",
    "ipr_subject",
    "ts",
    "policy",
    "gate",
    "hashes",
    "exec",
    "chain",
    "sig"
  ],
  "properties": {
    "v": { "type": "string", "const": "HBCE-EVIDENCE-1" },

    "request_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },

    "ipr_subject": { "type": "string", "minLength": 3, "maxLength": 128 },

    "ts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },

    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "result", "reasons"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "result": { "type": "string", "enum": ["PASS", "DENY"] },
        "reasons": {
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },

    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "reasons"],
      "properties": {
        "result": { "type": "string", "enum": ["ALLOW", "DENY"] },
        "reasons": {
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },

    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_hash"],
      "properties": {
        "input_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "plan_hash": {
          "type": ["string", "null"],
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "output_hash": {
          "type": ["string", "null"],
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },

    "exec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "tool_trace"],
      "properties": {
        "status": { "type": "string", "enum": ["OK", "ERROR", "SKIPPED"] },
        "tool_trace": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2048,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "error": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "code": { "type": "string", "maxLength": 128 },
            "message": { "type": "string", "maxLength": 2000 }
          }
        },
        "rollback": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "attempted": { "type": "boolean" },
            "status": { "type": "string", "enum": ["OK", "ERROR"] },
            "notes": { "type": "string", "maxLength": 2000 }
          }
        }
      }
    },

    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prev_entry_hash", "entry_hash", "height"],
      "properties": {
        "prev_entry_hash": {
          "type": ["string", "null"],
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "entry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "height": { "type": "integer", "minimum": 0 }
      }
    },

    "sig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "by", "value"],
      "properties": {
        "alg": { "type": "string", "enum": ["ed25519"] },
        "by": { "type": "string", "minLength": 1, "maxLength": 128 },
        "value": { "type": "string", "minLength": 32, "maxLength": 4096 }
      }
    }
  }
}
